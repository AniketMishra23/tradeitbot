# .env.example — copy this file to .env and fill in your keys
# cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Telegram bot token — get one from @BotFather on Telegram (free)
BOT_TOKEN=your_telegram_bot_token_here

# ── AI providers (at least one required for Explain / Chat) ───────────────────

# Groq API key — primary AI provider (llama-3.3-70b)
# Free at: https://console.groq.com  (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API key — fallback if Groq is unavailable or rate-limited
# Free at: https://ai.google.dev  (no credit card needed)
GEMINI_API_KEY=your_gemini_api_key_here
